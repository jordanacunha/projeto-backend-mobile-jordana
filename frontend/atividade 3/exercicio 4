<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <title>Login de Usuário</title>
</head>
<body>
  <h1>Acessar o Sistema</h1>
  <form>
    <label for="login-email">E-mail Acadêmico:</label><br>
    <input type="email" id="login-email" name="login-email" placeholder="Digite seu e-mail"><br><br>

    <label for="login-senha">Senha:</label><br>
    <input type="password" id="login-senha" name="login-senha" placeholder="Digite sua senha"><br><br>

    <button type="submit">Entrar</button>
  </form>
</body>
</html>