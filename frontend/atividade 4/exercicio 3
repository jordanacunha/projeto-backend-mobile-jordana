<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <title>Página 3</title>
  <style>
    body {
      font-family: Arial, sans-serif;
      background-color: #ddaaec;
      padding: 20px;
    }
    .form-cadastro {
      background-color: white;
      padding: 25px;
      border-radius: 8px;
      max-width: 450px;
      margin: 0 auto;
      box-shadow: 0 4px 6px rgba(0, 0, 0, 0.05);
    }
    label {
      font-weight: bold;
      color: #380275;
    }
    input {
      width: 100%;
      padding: 8px;
      margin-top: 6px;
      margin-bottom: 16px;
      border: 1px solid #ddaaec;
      border-radius: 4px;
      box-sizing: border-box;
    }
    button {
      width: 100%;
      background-color: #a44cbf; 
      color: white;
      padding: 10px;
      border: none;
      border-radius: 4px;
      font-size: 16px;
    }
  </style>
</head>
<body>
  <div class="form-cadastro">
    <h2>Cadastro de Aluno</h2>
    <form>
      <label for="nome">Nome Completo</label>
      <input type="text" id="nome" placeholder="Nome do aluno">

      <label for="matricula">CGM Escolar</label>
      <input type="text" id="CGM Escolar" placeholder="Ex: 20261234">

      <button type="submit">Concluir Matrícula</button>
    </form>
  </div>
</body>
</html>