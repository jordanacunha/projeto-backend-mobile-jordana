const express = require('express');
const cors = require('cors');
const app = express();
app.use(cors());
app.use(express.json());

// Dados simulados já cadastrados no servidor
let avisos = [
  { id: 1, titulo: 'Manutenção do sistema no domingo às 02h.' },
  { id: 2, titulo: 'Nova versão do app liberada!' }
];

app.get('/avisos', (req, res) => {
  res.json(avisos);
});

app.listen(3000, () => console.log('Servidor rodando na porta 3000'));